#!/usr/bin/env bash
# Discord CLI — terminal client for Discord (Exocortex external tool).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
PYTHON="$PROJECT_DIR/.venv/bin/python3"

export PYTHONPATH="$PROJECT_DIR"

usage() {
    cat <<'EOF'
usage: discord <command> [args]

commands:
  guilds       List your servers                       (alias: servers)
  guild        Show server details                     (alias: server)
  channels     List channels in a server              (alias: chs)
  messages     Read messages from a channel           (alias: msgs)
  download     Download message attachment(s)
  dms          List DM conversations
  dm           Read or send DMs                       (--browser for browser-native send)
  search       Search messages                        (alias: s)
  pins         Get pinned messages
  threads      List active threads in a server
  members      List or search server members
  me           Show current user info
  send         Send a message
  reply        Reply to a message
  edit         Edit a message
  delete       Delete a message                       (alias: del)
  react        React to a message
  unreact      Remove a reaction
  call         Start/join/manage Discord calls (start/join detach by default; mute/deafen/leave/list)
  listen       Start real-time channel listener
  unlisten     Stop a channel listener
  listeners    List active listeners
  notify       Manage notification relay              (add, remove, label, list, start, stop)
  join         Join a server via invite link          (browser-native default; --raw for legacy path)
  leave        Leave a server
  typing       Trigger typing indicator
  read         Mark channel as read
  captcha      Manage browser-backed captcha flow     (setup, status, solve)
  web          Manage dedicated Discord web profile   (setup, status, seed-accessibility,
                                                      broker-start, broker-status, broker-stop,
                                                      send-dm, join-invite)
  login        Save and validate an auth token       (alias: setup, auth)
  logout       Remove saved credentials

notes:
  - Browser-native paths use a dedicated persistent Chromium profile under config/web/
  - `discord join` prefers the browser-native path because invite joins commonly trigger captcha
  - `discord dm --send` can use `--browser`, and may auto-fallback on captcha-like API failures

Run 'discord <command> --help' for command-specific usage.
Run 'discord web --help' for browser-native subcommands.
EOF
}

web_usage() {
    cat <<'EOF'
usage: discord web <subcommand> [args]

subcommands:
  setup               Open the dedicated Chromium profile for manual Discord login/bootstrap
  status              Show local profile + broker status
  seed-accessibility  Copy hCaptcha accessibility cookies from the best available source
  broker-start        Start/reuse the persistent browser broker
  broker-status       Show persistent broker status
  broker-stop         Stop the persistent broker
  send-dm             Send a DM through the browser-native path
  join-invite         Join an invite through the browser-native path

notes:
  - The broker keeps one dedicated Chromium session alive to avoid relaunching Chrome per command
  - Headless is the default; use --headed only for debugging
  - `seed-accessibility` imports hCaptcha accessibility state from the best available source
    (captcha profile first if valid, otherwise live qutebrowser runtime cookies)
EOF
}

if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

cmd="$1"; shift

case "$cmd" in
    guilds|servers|guild|server|channels|chs|messages|msgs|dms|dm|search|s|pins|threads|members|me)
        exec "$PYTHON" -c "import sys; from src.reading import dispatch; dispatch('$cmd', sys.argv[1:])" "$@" ;;
    download)
        exec "$PYTHON" -c "import sys; from src.downloading import dispatch; dispatch('$cmd', sys.argv[1:])" "$@" ;;
    send|reply|edit|delete|del|react|unreact)
        exec "$PYTHON" -c "import sys; from src.writing import dispatch; dispatch('$cmd', sys.argv[1:])" "$@" ;;
    call|voice|join-call)
        exec "$PYTHON" -c "import sys; from src.calling import dispatch; dispatch('$cmd', sys.argv[1:])" "$@" ;;
    listen|unlisten|listeners)
        exec "$PYTHON" -c "import sys; from src.listening import dispatch; dispatch('$cmd', sys.argv[1:])" "$@" ;;
    notify)
        exec "$PYTHON" -c "import sys; from src.notify import dispatch; dispatch('$cmd', sys.argv[1:])" "$@" ;;
    join|leave|typing|read)
        exec "$PYTHON" -c "import sys; from src.managing import dispatch; dispatch('$cmd', sys.argv[1:])" "$@" ;;
    captcha)
        if [[ $# -eq 0 ]]; then
            echo "usage: discord captcha <setup|status|solve>" >&2
            exit 1
        fi
        subcmd="$1"; shift
        exec "$PYTHON" -c "import sys; from src.captcha_cli import dispatch; dispatch('$subcmd', sys.argv[1:])" "$@" ;;
    web)
        if [[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" || "$1" == "help" ]]; then
            web_usage
            exit 0
        fi
        subcmd="$1"; shift
        exec "$PYTHON" -c "import sys; from src.websession_cli import dispatch; dispatch('$subcmd', sys.argv[1:])" "$@" ;;
    login|setup|auth|logout)
        exec "$PYTHON" -c "import sys; from src.auth import dispatch; dispatch('$cmd', sys.argv[1:])" "$@" ;;
    help|--help|-h)
        usage ;;
    *)
        echo "discord: unknown command '$cmd'" >&2
        echo "Run 'discord --help' for usage." >&2
        exit 1 ;;
esac
